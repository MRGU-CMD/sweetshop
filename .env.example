# Database (Neon Serverless Postgres)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=verify-full"

# Auth (NextAuth.js)
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000

# OAuth Providers (optional — leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_WECHAT_ID=
AUTH_WECHAT_SECRET=
AUTH_QQ_ID=
AUTH_QQ_SECRET=

# Email (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=
EMAIL_FROM="SweetShop <noreply@sweetshop.com>"

# File Storage (Vercel Blob)
# Get your token from Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=

# Rate Limiting (Vercel KV)
# Get these from Vercel Dashboard > Storage > KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Seed (optional — defaults are used if not set)
# SEED_ADMIN_PASSWORD=admin123
# SEED_DEMO_PASSWORD=123456
